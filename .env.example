# ===========================================
# Dispute2Go Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# REQUIRED - Core Application
# ===========================================

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/dispute2go?schema=public"

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="generate-a-secure-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# JWT for client portal (can be same as NEXTAUTH_SECRET)
JWT_SECRET="generate-another-secure-secret-at-least-32-chars"

# PII Encryption Key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Required for encrypting SSN, DOB, phone, and address fields at rest
ENCRYPTION_KEY=""

# ===========================================
# PAYMENTS (Stripe)
# ===========================================

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ===========================================
# FILE STORAGE
# ===========================================

# Storage provider: "local", "s3", or "r2"
STORAGE_PROVIDER="local"
STORAGE_BUCKET="dispute2go-uploads"
UPLOAD_DIR="./uploads"

# Max file size in MB
MAX_FILE_SIZE_MB=50

# AWS S3 (if STORAGE_PROVIDER="s3")
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_ENDPOINT="" # Leave empty for AWS, or set for S3-compatible services

# Cloudflare R2 (if STORAGE_PROVIDER="r2")
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_URL=""

# ===========================================
# EMAIL (Resend)
# ===========================================

RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_REPLY_TO="support@yourdomain.com"

# ===========================================
# SMS (Twilio)
# ===========================================

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID="" # Optional, for high-volume

# ===========================================
# AI/LLM Providers
# ===========================================

# At least one is recommended for letter generation
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Default provider: "claude" or "openai"
DEFAULT_LLM_PROVIDER="claude"

# Model preferences
CLAUDE_MODEL="claude-sonnet-4-20250514"
OPENAI_MODEL="gpt-4-turbo"

# ===========================================
# REDIS (Rate Limiting, Caching, Queues)
# ===========================================

# Full Redis URL (takes precedence over individual settings)
REDIS_URL=""

# Or individual settings
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# ===========================================
# PHYSICAL MAIL (Lob)
# ===========================================

LOB_API_KEY=""
LOB_TEST_MODE="true" # Set to "false" in production

# ===========================================
# CREDIT MONITORING APIs
# ===========================================

# IdentityIQ Integration
IDENTITYIQ_API_KEY=""
IDENTITYIQ_PARTNER_ID=""

# Array/SmartCredit (alternative)
ARRAY_API_KEY=""
ARRAY_CLIENT_KEY=""

# ===========================================
# ERROR TRACKING & MONITORING
# ===========================================

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# LogRocket (optional frontend monitoring)
NEXT_PUBLIC_LOGROCKET_APP_ID=""

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable/disable features
FEATURE_EMAIL_ENABLED="true"
FEATURE_SMS_ENABLED="false"
FEATURE_AI_ENABLED="true"
FEATURE_STRIPE_ENABLED="false"
FEATURE_CLOUD_STORAGE_ENABLED="false"
FEATURE_PHYSICAL_MAIL_ENABLED="false"
FEATURE_CREDIT_MONITORING_ENABLED="false"

# ===========================================
# APP CONFIG
# ===========================================

NODE_ENV="development"

# Application URL (used in emails, links)
APP_URL="http://localhost:3000"

# Portal URL (if separate from main app)
PORTAL_URL="http://localhost:3000/portal"

# Company branding defaults
DEFAULT_COMPANY_NAME="Dispute2Go"
DEFAULT_SUPPORT_EMAIL="support@dispute2go.com"
DEFAULT_SUPPORT_PHONE=""

# ===========================================
# SECURITY
# ===========================================

# Rate limiting (requests per minute)
RATE_LIMIT_API="100"
RATE_LIMIT_AUTH="10"
RATE_LIMIT_UPLOAD="10"

# Session settings
SESSION_MAX_AGE="86400" # 24 hours in seconds
PORTAL_SESSION_MAX_AGE="3600" # 1 hour for client portal

# ===========================================
# DEVELOPMENT ONLY
# ===========================================

# Skip email verification in development
SKIP_EMAIL_VERIFICATION="true"

# Enable debug logging
DEBUG="false"

# Disable SSL verification (NEVER in production)
NODE_TLS_REJECT_UNAUTHORIZED="" # Set to "0" only for local testing
